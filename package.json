{
  "name": "orbit-ai",
  "productName": "Orbit AI",
  "version": "1.0.0",
  "description": "AI-powered desktop code editor with integrated AI assistant",
  "main": ".webpack/main",
  "private": true,
  "config": {
    "forge": "forge.config.ts"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "start": "echo \"[Orbit AI] If UI shows 'did not mount' error: kill stale node.exe on dev ports then restart.\" && electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx .",
    "postinstall": "electron-rebuild --force --arch=x64",
    "rebuild": "electron-rebuild --force --arch=x64",
    "predist": "node scripts/webpack-build.cjs",
    "dist": "electron-builder --win",
    "app": "powershell -ExecutionPolicy Bypass -NoProfile -File scripts/release.ps1",
    "clean": "if exist dist-installer rmdir /s /q dist-installer && if exist out rmdir /s /q out"
  },
  "keywords": [],
  "author": {
    "name": "Jayakrishnan PS",
    "email": "jayakrishnanps12@gmail.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-webpack": "^7.11.2",
    "@electron/fuses": "^1.8.0",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vercel/webpack-asset-relocator-loader": "^1.7.3",
    "css-loader": "^6.11.0",
    "electron": "^42.0.0",
    "electron-builder": "^26.15.0",
    "electron-rebuild": "^3.2.9",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "fork-ts-checker-webpack-plugin": "^7.3.0",
    "monaco-editor-webpack-plugin": "^7.1.1",
    "node-loader": "^2.1.0",
    "style-loader": "^3.3.4",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "electron-squirrel-startup": "^1.0.1",
    "groq-sdk": "^1.2.0",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.1.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "build": {
    "extraMetadata": {
      "main": ".webpack/main/index.js"
    },
    "appId": "com.jayakrishnanps.orbit-ai",
    "productName": "Orbit AI",
    "copyright": "Copyright © 2026 Jayakrishnan PS",
    "directories": {
      "output": "dist-installer"
    },
    "files": [
      ".webpack/**/*",
      "!.webpack/**/*.js.map",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "**/node-pty/**",
      "**/*.node"
    ],
    "extraResources": [
      {
        "from": "node_modules/node-pty/",
        "to": "node-pty/",
        "filter": [
          "build/**",
          "lib/**",
          "package.json"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Orbit AI",
      "license": "LICENSE.txt",
      "perMachine": false,
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true,
      "menuCategory": false
    }
  }
}
